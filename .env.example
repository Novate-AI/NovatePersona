VITE_BACKEND_URL=http://localhost:5000/api/chat
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# TTS voice for en-GB (Piper): en_GB-cori (female), en_GB-alan (male), en_GB-southern_english_female, etc.
# VITE_TTS_VOICE_EN_GB=en_GB-cori

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxx

# For npm run deploy:novatutor (get from https://supabase.com/dashboard/account/tokens)
# SUPABASE_ACCESS_TOKEN=your-access-token
